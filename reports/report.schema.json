{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "YAMTAM Audit Report",
  "description": "Output schema for yamtam audit . — deterministic agent setup risk scan",
  "version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "generated_at", "target", "score", "risk_level", "summary", "findings"],

  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Report schema version — semver",
      "example": "0.1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when the scan completed"
    },
    "target": {
      "type": "string",
      "description": "Path scanned, relative to cwd — typically '.' or './myrepo'"
    },
    "yamtam_version": {
      "type": "string",
      "description": "YAMTAM CLI version that produced this report",
      "example": "0.1.0"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Risk score. Start 100. CRITICAL -30 / HIGH -20 / MEDIUM -10 / LOW -3. Floor at 0."
    },
    "risk_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
      "description": "Derived from score: 90-100=LOW | 70-89=MEDIUM | 40-69=HIGH | 0-39=CRITICAL"
    },
    "summary": {
      "type": "object",
      "required": ["total", "critical", "high", "medium", "low"],
      "properties": {
        "total":    { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 },
        "high":     { "type": "integer", "minimum": 0 },
        "medium":   { "type": "integer", "minimum": 0 },
        "low":      { "type": "integer", "minimum": 0 },
        "info":     { "type": "integer", "minimum": 0 }
      }
    },
    "scan_stats": {
      "type": "object",
      "description": "Metadata about what was scanned",
      "properties": {
        "files_scanned":   { "type": "integer" },
        "files_skipped":   { "type": "integer" },
        "scanners_run":    { "type": "integer" },
        "checks_applied":  { "type": "integer" },
        "duration_ms":     { "type": "integer" }
      }
    },
    "analytics": {
      "type": "object",
      "description": "Aggregated analytics over findings — useful for dashboards and trend tracking",
      "properties": {
        "by_category": {
          "type": "object",
          "description": "Finding count per scanner scope (e.g. ci-workflows: 5)",
          "additionalProperties": { "type": "integer" }
        },
        "top_rules": {
          "type": "array",
          "description": "Rules ranked by severity then instance count — high count = systemic issue",
          "items": {
            "type": "object",
            "properties": {
              "id":       { "type": "string" },
              "severity": { "type": "string", "enum": ["CRITICAL","HIGH","MEDIUM","LOW","INFO"] },
              "count":    { "type": "integer", "minimum": 1 },
              "category": { "type": "string" }
            }
          }
        },
        "files_with_findings": { "type": "integer", "minimum": 0 },
        "files_clean":         { "type": "integer", "minimum": 0 },
        "hit_rate_pct":        { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "file", "rule", "reason", "fix"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Finding ID — rule prefix + 3-digit number e.g. AC002, SH001, MCP003",
            "pattern": "^[A-Z]{2,3}[0-9]{3}$"
          },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"],
            "description": "CRITICAL and HIGH require immediate action. LOW/INFO are informational."
          },
          "category": {
            "type": "string",
            "enum": ["agent-config", "shell-risk", "mcp-permission", "ci-workflow", "secret-exposure"],
            "description": "Scanner category that produced this finding"
          },
          "file": {
            "type": "string",
            "description": "Relative path to the file where the finding was detected"
          },
          "line": {
            "type": "integer",
            "minimum": 1,
            "description": "Line number within the file — omit if not applicable (e.g. JSON key match)"
          },
          "rule": {
            "type": "string",
            "description": "Human-readable rule slug e.g. 'agent-config/wildcard-bash', 'shell-risk/pipe-to-shell'"
          },
          "reason": {
            "type": "string",
            "description": "Why this is a risk — one or two sentences, non-jargon"
          },
          "fix": {
            "type": "string",
            "description": "Concrete action the developer can take to resolve this finding"
          },
          "confidence": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"],
            "description": "HIGH = deterministic match. MEDIUM = likely match. LOW = may be false positive.",
            "default": "HIGH"
          },
          "matched_value": {
            "type": "string",
            "description": "The specific value or snippet that triggered the rule — omit for secrets to avoid leaking"
          }
        }
      }
    }
  },

  "examples": [
    {
      "schema_version": "0.1.0",
      "generated_at": "2026-05-26T10:30:00Z",
      "target": ".",
      "yamtam_version": "0.1.0",
      "score": 41,
      "risk_level": "HIGH",
      "summary": { "total": 5, "critical": 1, "high": 2, "medium": 1, "low": 1, "info": 0 },
      "scan_stats": {
        "files_scanned": 14,
        "files_skipped": 2,
        "scanners_run": 5,
        "checks_applied": 48,
        "duration_ms": 120
      },
      "findings": [
        {
          "id": "AC002",
          "severity": "CRITICAL",
          "category": "agent-config",
          "file": ".claude/settings.json",
          "line": 8,
          "rule": "agent-config/wildcard-bash",
          "reason": "allowedTools contains Bash(*) — wildcard shell access lets the agent run any command without restriction.",
          "fix": "Replace Bash(*) with scoped entries like Bash(git status) or Bash(npm test).",
          "confidence": "HIGH",
          "matched_value": "Bash(*)"
        }
      ]
    }
  ]
}
