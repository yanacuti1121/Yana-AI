[2.5254, "o", "\u001b[0;31m\u001b[1m[Yana AI BLOCK]\u001b[0m guard-destructive.sh — rm -rf detected. Hard block.\r\n\u001b[0;31m  Decision: DENY\u001b[0m\r\n"]
[3.3294, "o", "\r\n"]
