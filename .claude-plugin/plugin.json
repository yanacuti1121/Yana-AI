{
  "schema_version": "1",
  "name": "yamtam-engine",
  "display_name": "YAMTAM ENGINE",
  "version": "1.3.28",
  "description": "Personal agent operating system for Claude Code. Safety hooks, memory tiers, agents, and commands.",
  "author": "phamlongh230-lgtm",
  "homepage": "https://github.com/phamlongh230-lgtm/yamtam-engine",
  "license": "MIT",
  "keywords": [
    "hooks",
    "safety",
    "memory",
    "agents",
    "gates",
    "guards"
  ],
  "install": {
    "type": "zip",
    "source": "https://github.com/phamlongh230-lgtm/yamtam-engine/releases/latest/download/yamtam-engine-latest.zip",
    "target": ".claude/",
    "post_install": "bash .claude/tests/hooks/run-hook-tests.sh"
  },
  "contents": {
    "hooks": 26,
    "commands": 156,
    "agents": 87,
    "scripts": 22,
    "skills": 83,
    "checks": 131,
    "checks_breakdown": {
      "hook_tests": 55,
      "audit_chain_tests": 12,
      "skill_trigger_checks": 58,
      "command_smoke_checks": 6
    },
    "memory_tiers": [
      "L1_atomic",
      "L2_session"
    ]
  },
  "requires": {
    "claude_code": ">=1.0.0",
    "shell": "bash",
    "tools": [
      "jq"
    ]
  }
}
