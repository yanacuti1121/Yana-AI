{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yamtam.local/schemas/run-log.schema.json",
  "title": "YAMTAM Run Log",
  "description": "Schema for recording runtime, token, and verification evidence metadata for internal Runtime & Cost Gate analysis.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "started_at",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/-]{6,128}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/-]{3,128}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "completed",
        "failed",
        "aborted"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "repo_ref": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "budget": {
      "type": "object",
      "properties": {
        "token_limit": {
          "type": "integer",
          "minimum": 1
        },
        "runtime_seconds_limit": {
          "type": "integer",
          "minimum": 1
        },
        "max_changed_files": {
          "type": "integer",
          "minimum": 0
        },
        "max_diff_lines": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "usage": {
      "type": "object",
      "properties": {
        "tokens_used": {
          "type": "integer",
          "minimum": 0
        },
        "runtime_seconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "changes": {
      "type": "object",
      "properties": {
        "changed_files": {
          "type": "integer",
          "minimum": 0
        },
        "diff_lines": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "verification": {
      "type": "object",
      "properties": {
        "evidence_present": {
          "type": "boolean"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "ref"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "command-output",
                  "file",
                  "ci-log",
                  "link",
                  "note"
                ]
              },
              "ref": {
                "type": "string",
                "minLength": 1
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": true
          }
        },
        "verification_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "completed",
              "failed",
              "aborted"
            ]
          }
        }
      },
      "then": {
        "required": [
          "ended_at"
        ]
      }
    }
  ],
  "patternProperties": {
    "^x-[A-Za-z0-9._-]+$": {}
  },
  "additionalProperties": false
}
