{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": \"IDEA LOOP AUTO-START: Ngay khi nh\u1eadn tin nh\u1eafn \u0111\u1ea7u ti\u00ean t\u1eeb ng\u01b0\u1eddi d\u00f9ng, h\u00e3y ch\u1ea1y /idea-loop \u0111\u1ec3 ki\u1ec3m tra tr\u1ea1ng th\u00e1i repo v\u00e0 g\u1ee3i \u00fd vi\u1ec7c l\u00e0m. Ch\u1ea1y tr\u01b0\u1edbc khi x\u1eed l\u00fd y\u00eau c\u1ea7u c\u1ee7a ng\u01b0\u1eddi d\u00f9ng.\"}}'",
            "statusMessage": "Kh\u1edfi \u0111\u1ed9ng Idea Loop..."
          },
          {
            "type": "command",
            "command": "python3 -c \"from headroom import compress; print('[headroom] ready')\" 2>/dev/null || true",
            "statusMessage": "Headroom context compressor..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-destructive.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scope-guard.sh"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/token-budget-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/phamlongh230/yamtam-engine/.claude/hooks/truth-gate-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/audit-log.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/budget-sentinel.sh"
          }
        ]
      }
    ]
  }
}